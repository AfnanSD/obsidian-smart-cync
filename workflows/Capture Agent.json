    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map((item) => {\n\n  const text =\n    item.json?.message?.text || \"\";\n\n  // Split on \". \"  => [url, \"10 min\", \"blog\", \"title\"]\n  const parts = text.split('. ').map(p => p.trim()).filter(Boolean);\n\n  return {\n    json: {\n      url: parts[0] || \"\",\n      type: parts[1] || \"\",\n      length: parts[2] || \"\",\n      extra: parts[3] || \"\"      \n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
