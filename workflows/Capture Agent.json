    {
      "parameters": {
        "jsCode": "// HTML from HTTP Request output\nconst html = $json.data || \"\";\n\n// Extract og:title first, fallback to <title>\nconst og = html.match(/<meta[^>]+property=[\"']og:title[\"'][^>]+content=[\"']([^\"']+)[\"']/i);\nconst titleTag = html.match(/<title[^>]*>([^<]+)<\\/title>/i);\n\nconst title =\n  (og && og[1] ? og[1].trim() : \"\") ||\n  (titleTag && titleTag[1] ? titleTag[1].trim() : \"\") ||\n  \"(title not found)\";\n\nreturn [{ json: { title } }];\n"
      },
